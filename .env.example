# copy this file and rename it to .env before running the test
# fill in your own values below

# your beeceptor endpoint name (just the name, not full url)
# example - if your url is https://jagan-test.free.beeceptor.com
# then write jagan-test only
BEECEPTOR_ENDPOINT=your-endpoint-name

# this is the path which will trigger the callout rule
TRIGGER_PATH=/create-order

# beeceptor will send callout request to this path
CALLOUT_PATH=/order-callback-received

# this is your beeceptor login session cookie
# how to get this value -
# 1. open app.beeceptor.com in chrome and login
# 2. press F12 and go to Application tab
# 3. click on Cookies on left side
# 4. click on https://app.beeceptor.com
# 5. find beesession and copy its value
# 6. paste it here
BEESESSION=paste-your-beesession-value-here