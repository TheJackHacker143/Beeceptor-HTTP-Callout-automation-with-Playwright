# Copy this file to ".env" and fill in your own values before running the tests.
# Never commit your real ".env" file - it might contain login info.

# Your Beeceptor endpoint name (the subdomain part only, not the full URL)
# Example: if your mock server URL is https://jagan-test.proxy.beeceptor.com
# then BEECEPTOR_ENDPOINT=jagan-test
BEECEPTOR_ENDPOINT=jagan-callout-demo

# Beeceptor login email and password.
# You need a logged-in session to create/edit Mock Rules from the dashboard.
BEECEPTOR_EMAIL=your-email@example.com
BEECEPTOR_PASSWORD=your-password

# The path on our Beeceptor endpoint that will trigger the callout rule
# Example: /create-order
TRIGGER_PATH=/create-order

# The callout target path. In this assignment we simply call back into the
# SAME Beeceptor endpoint on a different path, so everything can be verified
# in one place without needing a second public server.
CALLOUT_PATH=/order-callback-received
